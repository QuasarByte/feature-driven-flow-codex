{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/fdf-effective-matrix.schema.json",
  "title": "FDF Effective Rule Matrix Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "fdf_version",
    "created_at",
    "selected_profiles",
    "profile_overrides",
    "enabled_packs",
    "rule_matrix"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "fdf/effective-rule-matrix.v1"
    },
    "fdf_version": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "selected_profiles": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "profile_overrides": {
      "type": "object"
    },
    "enabled_packs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "rule_matrix": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scope",
        "explore",
        "clarify",
        "architect",
        "implement",
        "verify",
        "summarize"
      ],
      "properties": {
        "scope": { "$ref": "#/$defs/ruleIdList" },
        "explore": { "$ref": "#/$defs/ruleIdList" },
        "clarify": { "$ref": "#/$defs/ruleIdList" },
        "architect": { "$ref": "#/$defs/ruleIdList" },
        "implement": { "$ref": "#/$defs/ruleIdList" },
        "verify": { "$ref": "#/$defs/ruleIdList" },
        "summarize": { "$ref": "#/$defs/ruleIdList" }
      }
    },
    "context_model": {
      "type": "object",
      "additionalProperties": true
    },
    "notes": {
      "type": "string"
    }
  },
  "$defs": {
    "ruleIdList": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  }
}
